{"file":"default-D6nZRVv7.js","mappings":";;;;;;;;;;;;;;;;;;;;AAEA,UAAM,EAAE,GAAG,OAAkB,IAAI,UAAS;AAC1C,UAAM,eAAc,oBAAI,KAAI,GAAG,YAAW;;;6GAcPA,MAAA,CAAA,EAAC,OAAA,CAAA;;QAElB,IAAG;AAAA,QAAI,gBAAa;AAAA;yBAA9B,CAAqE,GAAAC,QAAAC,UAAA,aAAA;;qCAA3BF,MAAA,CAAA,EAAC,UAAA,CAAA,CAAA,EAAA;AAAA;;8CAADA,MAAA,CAAA,EAAC,UAAA,CAAA,GAAA,CAAA;AAAA;;;;;;QACjC,IAAG;AAAA,QAAgB,gBAAa;AAAA;yBAA1C,CAEa,GAAAC,QAAAC,UAAA,aAAA;;qCADXF,MAAA,CAAA,EAAC,iBAAA,CAAA,CAAA,EAAA;AAAA;;8CAADA,MAAA,CAAA,EAAC,iBAAA,CAAA,GAAA,CAAA;AAAA;;;;;;QAEO,IAAG;AAAA,QAAa,gBAAa;AAAA;yBAAvC,CAEa,GAAAC,QAAAC,UAAA,aAAA;;qCADXF,MAAA,CAAA,EAAC,eAAA,CAAA,CAAA,EAAA;AAAA;;8CAADA,MAAA,CAAA,EAAC,eAAA,CAAA,GAAA,CAAA;AAAA;;;;;;QAEO,IAAG;AAAA,QAAc,gBAAa;AAAA;yBAAxC,CAEa,GAAAC,QAAAC,UAAA,aAAA;;qCADXF,MAAA,CAAA,EAAC,eAAA,CAAA,CAAA,EAAA;AAAA;;8CAADA,MAAA,CAAA,EAAC,eAAA,CAAA,GAAA,CAAA;AAAA;;;;;;QAEO,IAAG;AAAA,QAAa,gBAAa;AAAA;yBAAvC,CAEa,GAAAC,QAAAC,UAAA,aAAA;;qCADXF,MAAA,CAAA,EAAC,aAAA,CAAA,CAAA,EAAA;AAAA;;8CAADA,MAAA,CAAA,EAAC,aAAA,CAAA,GAAA,CAAA;AAAA;;;;;;QAEO,IAAG;AAAA,QAAW,gBAAa;AAAA;yBAArC,CAEa,GAAAC,QAAAC,UAAA,aAAA;;qCADXF,MAAA,CAAA,EAAC,aAAA,CAAA,CAAA,EAAA;AAAA;;8CAADA,MAAA,CAAA,EAAC,aAAA,CAAA,GAAA,CAAA;AAAA;;;;;mJAOiBA,MAAA,MAAA,MAAM,KAAA,GAAA,WAAA,CAAA,kGASNA,MAAA,MAAA,MAAM,KAAA,GAAA,WAAA,CAAA,iGASNA,MAAA,MAAA,MAAM,KAAA,GAAA,WAAA,CAAA;;wDAUtBA,MAAA,CAAA,EAAC,QAAA,CAAA,gDACqBA,MAAA,WAAA,CAAW,oBAAOA,MAAA,CAAA,EAAC,OAAA,CAAA;;;;;;;;;;","names":["_unref","_push","_parent"],"sources":["../../../../../../../app/layouts/default.vue"],"sourcesContent":["<script setup>\nimport { useLocale } from \"../../composables/useLocale\";\nconst { t, locale, setLocale } = useLocale();\nconst currentYear = new Date().getFullYear();\n\nconst changeLocale = (value) => {\n  if (locale.value === value) {\n    return;\n  }\n\n  setLocale(value);\n};\n</script>\n\n<template>\n  <div>\n    <header class=\"navbar\">\n      <div class=\"navbar-brand\">{{ t(\"brand\") }}</div>\n      <nav class=\"navbar-links\">\n        <NuxtLink to=\"/\" active-class=\"active\">{{ t(\"nav.home\") }}</NuxtLink>\n        <NuxtLink to=\"/savoir-faire\" active-class=\"active\">{{\n          t(\"nav.savoirFaire\")\n        }}</NuxtLink>\n        <NuxtLink to=\"/creations\" active-class=\"active\">{{\n          t(\"nav.creations\")\n        }}</NuxtLink>\n        <NuxtLink to=\"/sur-mesure\" active-class=\"active\">{{\n          t(\"nav.surMesure\")\n        }}</NuxtLink>\n        <NuxtLink to=\"/l-atelier\" active-class=\"active\">{{\n          t(\"nav.atelier\")\n        }}</NuxtLink>\n        <NuxtLink to=\"/contact\" active-class=\"active\">{{\n          t(\"nav.contact\")\n        }}</NuxtLink>\n      </nav>\n      <div class=\"lang-switcher\" role=\"group\" aria-label=\"Changer la langue\">\n        <button\n          class=\"lang-flag\"\n          type=\"button\"\n          :class=\"{ active: locale === 'fr' }\"\n          aria-label=\"Français\"\n          @click=\"changeLocale('fr')\"\n        >\n          🇫🇷\n        </button>\n        <button\n          class=\"lang-flag\"\n          type=\"button\"\n          :class=\"{ active: locale === 'en' }\"\n          aria-label=\"English\"\n          @click=\"changeLocale('en')\"\n        >\n          🇬🇧\n        </button>\n        <button\n          class=\"lang-flag\"\n          type=\"button\"\n          :class=\"{ active: locale === 'jp' }\"\n          aria-label=\"日本語\"\n          @click=\"changeLocale('jp')\"\n        >\n          🇯🇵\n        </button>\n      </div>\n    </header>\n    <slot />\n    <footer class=\"footer\">\n      <p>{{ t(\"footer\") }}</p>\n      <p class=\"footer-copy\">© {{ currentYear }} {{ t(\"brand\") }}</p>\n    </footer>\n  </div>\n</template>\n"],"version":3}